.page {
  min-height: 100vh;
  padding-bottom: 120rpx;
}

.image-swiper {
  width: 100%;
  height: 750rpx;
  background: #f0f0f0;
}

.swiper-image {
  width: 100%;
  height: 100%;
}

.info-section {
  background: #fff;
  padding: 24rpx 20rpx;
  margin-top: 16rpx;
}

.price-row {
  align-items: flex-end;
}

.price {
  font-size: 44rpx;
}

.mt-15 { margin-top: 15rpx; }
.mt-5 { margin-top: 5rpx; }
.mr-10 { margin-right: 10rpx; }
.ml-15 { margin-left: 15rpx; }
.ml-20 { margin-left: 20rpx; }

.tag {
  display: inline-block;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
  font-size: 22rpx;
  color: #07c160;
  background: rgba(7, 193, 96, 0.1);
}

.avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: #f0f0f0;
}

/* Rating stars */
.rating-row {
  display: flex;
  align-items: center;
  gap: 6rpx;
  margin-top: 4rpx;
}

.rating-stars {
  font-size: 24rpx;
  color: #f5a623;
  letter-spacing: 2rpx;
}

.rating-text {
  font-size: 22rpx;
  color: #999;
}

.seller-badge {
  display: inline-block;
  font-size: 20rpx;
  color: #07c160;
  background: rgba(7, 193, 96, 0.1);
  padding: 2rpx 10rpx;
  border-radius: 8rpx;
  margin-top: 4rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  margin-bottom: 16rpx;
}

.description {
  font-size: 28rpx;
  line-height: 1.7;
  color: #666;
  white-space: pre-wrap;
}

.report-btn {
  text-align: center;
  padding: 12rpx;
  color: #999;
  font-size: 24rpx;
}

.report-btn:active {
  color: #ee0a24;
}

/* Bottom bar */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  padding: 16rpx 20rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  background: #fff;
  border-top: 1rpx solid #f0f0f0;
  z-index: 100;
}

.fav-btn {
  flex-direction: column;
  padding: 0 20rpx;
  font-size: 24rpx;
}

.like-icon {
  font-size: 36rpx;
  margin-bottom: 4rpx;
}

/* Rating Modal */
.modal-overlay {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0, 0, 0, 0.45);
  display: flex;
  align-items: flex-end;
  justify-content: center;
  z-index: 200;
}

.modal-sheet {
  background: #fff;
  width: 100%;
  border-radius: 24rpx 24rpx 0 0;
  padding: 30rpx;
  padding-bottom: calc(30rpx + env(safe-area-inset-bottom));
  animation: slideUp 0.3s ease;
}

@keyframes slideUp {
  from { transform: translateY(100%); }
  to { transform: translateY(0); }
}

.modal-title {
  font-size: 32rpx;
  font-weight: 700;
  text-align: center;
  margin-bottom: 20rpx;
}

.rating-modal {
  padding: 10rpx 0;
}

.rating-prompt {
  text-align: center;
  font-size: 28rpx;
  color: #666;
  margin-bottom: 24rpx;
}

.rating-star-row {
  display: flex;
  justify-content: center;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.rating-star-big {
  font-size: 60rpx;
  color: #ddd;
  transition: color 0.15s;
}

.rating-star-big.active {
  color: #f5a623;
}

.rating-comment {
  width: 100%;
  height: 140rpx;
  padding: 16rpx;
  border: 2rpx solid #eee;
  border-radius: 12rpx;
  font-size: 26rpx;
  box-sizing: border-box;
  margin-bottom: 20rpx;
}

.modal-btn-ghost {
  text-align: center;
  padding: 20rpx;
  color: #999;
  font-size: 26rpx;
  margin-top: 10rpx;
}
