.page {
  min-height: 100vh;
  padding-bottom: 120rpx;
}

.image-swiper {
  width: 100%;
  height: 750rpx;
  background: #f0f0f0;
}

.swiper-image {
  width: 100%;
  height: 100%;
}

.info-section {
  background: #fff;
  padding: 24rpx 20rpx;
  margin-top: 16rpx;
}

.price-row {
  align-items: flex-end;
}

.price {
  font-size: 44rpx;
}

.mt-15 { margin-top: 15rpx; }
.mt-5 { margin-top: 5rpx; }
.mr-10 { margin-right: 10rpx; }
.ml-15 { margin-left: 15rpx; }
.ml-20 { margin-left: 20rpx; }

.tag {
  display: inline-block;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
  font-size: 22rpx;
  color: #07c160;
  background: rgba(7, 193, 96, 0.1);
}

.avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: #f0f0f0;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  margin-bottom: 16rpx;
}

.description {
  font-size: 28rpx;
  line-height: 1.7;
  color: #666;
  white-space: pre-wrap;
}

/* 底部栏 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  padding: 16rpx 20rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  background: #fff;
  border-top: 1rpx solid #f0f0f0;
  z-index: 100;
}

.fav-btn {
  flex-direction: column;
  padding: 0 20rpx;
  font-size: 24rpx;
}

.like-icon {
  font-size: 36rpx;
  margin-bottom: 4rpx;
}
