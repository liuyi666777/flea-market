.page {
  min-height: 100vh;
  padding-bottom: 20rpx;
}

.search-bar {
  padding: 16rpx 20rpx;
  background: #fff;
  position: sticky;
  top: 0;
  z-index: 100;
}

.search-input {
  display: flex;
  align-items: center;
  height: 68rpx;
  background: #f5f5f5;
  border-radius: 34rpx;
  padding: 0 24rpx;
}

.search-icon {
  margin-right: 10rpx;
  font-size: 28rpx;
}

.search-placeholder {
  color: #999;
  font-size: 26rpx;
}

.category-scroll {
  white-space: nowrap;
  padding: 16rpx 20rpx;
  background: #fff;
}

.category-item {
  display: inline-flex;
  align-items: center;
  height: 56rpx;
  padding: 0 24rpx;
  margin-right: 16rpx;
  border-radius: 28rpx;
  font-size: 26rpx;
  color: #666;
  background: #f5f5f5;
  white-space: nowrap;
}

.category-item.active {
  color: #fff;
  background: #07c160;
}

.product-grid {
  display: flex;
  padding: 16rpx 20rpx;
  gap: 16rpx;
}

.product-col {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.load-more {
  text-align: center;
  padding: 30rpx;
  color: #999;
  font-size: 24rpx;
}
