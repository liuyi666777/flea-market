.page {
  min-height: 100vh;
  padding-bottom: 40rpx;
}

/* Tab bar */
.tab-bar-top {
  display: flex;
  background: #fff;
  border-bottom: 1rpx solid #f0f0f0;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  font-size: 28rpx;
  font-weight: 500;
  color: #999;
  border-bottom: 4rpx solid transparent;
}

.tab-item.active {
  color: #07c160;
  border-color: #07c160;
  font-weight: 600;
}

/* Report cards */
.report-card {
  background: #fff;
  margin: 16rpx 20rpx;
  border-radius: 16rpx;
  padding: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.report-header {
  margin-bottom: 12rpx;
}

.badge {
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  font-weight: 600;
}

.badge-pending {
  color: #ff6b35;
  background: #fff3ee;
}

.badge-resolved {
  color: #07c160;
  background: #e8f8ef;
}

.report-body {
  font-size: 28rpx;
  margin-bottom: 10rpx;
  line-height: 1.5;
}

.report-product {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 6rpx;
}

.tag-sm {
  display: inline-block;
  padding: 2rpx 10rpx;
  border-radius: 6rpx;
  font-size: 20rpx;
  color: #999;
  background: #f0f0f5;
  margin-left: 8rpx;
}

.report-meta {
  font-size: 22rpx;
  color: #aaa;
  margin-bottom: 14rpx;
}

.report-actions {
  display: flex;
  gap: 16rpx;
}

/* Search */
.search-row {
  padding: 16rpx 20rpx;
  background: #fff;
}

.search-input-admin {
  width: 100%;
  height: 68rpx;
  background: #f5f5f5;
  border-radius: 34rpx;
  padding: 0 24rpx;
  font-size: 26rpx;
  box-sizing: border-box;
}

/* Admin product cards */
.admin-product-card {
  display: flex;
  align-items: center;
  background: #fff;
  margin: 10rpx 20rpx;
  border-radius: 16rpx;
  padding: 16rpx;
  gap: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.admin-product-img {
  width: 120rpx;
  height: 120rpx;
  border-radius: 10rpx;
  flex-shrink: 0;
  background: #f5f5f8;
}

.admin-product-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 50rpx;
}

.admin-product-info {
  flex: 1;
  min-width: 0;
}

.admin-product-title {
  font-size: 28rpx;
  margin-bottom: 10rpx;
  line-height: 1.4;
}
