<view class="page">
  <!-- Tab 切换 -->
  <view class="tab-bar-top">
    <view class="tab-item {{activeTab === 'reports' ? 'active' : ''}}" data-tab="reports" bindtap="switchTab">🚩 举报管理</view>
    <view class="tab-item {{activeTab === 'products' ? 'active' : ''}}" data-tab="products" bindtap="switchTab">📦 商品管理</view>
  </view>

  <!-- 举报列表 -->
  <view wx:if="{{activeTab === 'reports'}}">
    <view class="empty-state" wx:if="{{reports.length === 0}}">
      <text class="icon">✅</text>
      <text class="text">暂无举报，社区很和谐~</text>
    </view>

    <view class="report-card" wx:for="{{reports}}" wx:key="id">
      <view class="report-header flex-between">
        <view class="badge {{item.status === 'pending' ? 'badge-pending' : 'badge-resolved'}}">
          {{item.status === 'pending' ? '待处理' : '已处理'}}
        </view>
        <text class="text-sm text-muted">{{item.timeAgo}}</text>
      </view>
      <view class="report-body">
        <text class="text-bold">举报原因：</text>{{item.reason}}
      </view>
      <view class="report-product" wx:if="{{products[item.product_id]}}">
        商品：{{products[item.product_id].title}}
        <text class="tag-sm">{{products[item.product_id].status}}</text>
      </view>
      <view class="report-meta">
        举报人：{{profiles[item.reporter_id] ? profiles[item.reporter_id].nickname : '用户'}}
        <text wx:if="{{products[item.product_id]}}"> | 卖家：{{profiles[products[item.product_id].user_id] ? profiles[products[item.product_id].user_id].nickname : '用户'}}</text>
      </view>
      <view class="report-actions">
        <view class="btn btn-outline btn-sm" wx:if="{{item.status === 'pending'}}" data-id="{{item.id}}" bindtap="resolveReport">✓ 标记已处理</view>
        <view class="btn btn-danger btn-sm" wx:if="{{products[item.product_id]}}" data-id="{{item.product_id}}" bindtap="deleteProduct">🗑 删除商品</view>
      </view>
    </view>
  </view>

  <!-- 商品管理 -->
  <view wx:if="{{activeTab === 'products'}}">
    <view class="search-row">
      <input class="search-input-admin" placeholder="搜索所有商品..." value="{{searchKeyword}}" bindinput="onSearchInput" />
    </view>

    <view class="empty-state" wx:if="{{filteredProducts.length === 0}}">
      <text class="icon">📦</text>
      <text class="text">未找到商品</text>
    </view>

    <view class="admin-product-card" wx:for="{{filteredProducts}}" wx:key="id">
      <image class="admin-product-img" src="{{item.images[0]}}" mode="aspectFill" wx:if="{{item.images && item.images.length}}" />
      <view class="admin-product-img admin-product-placeholder" wx:else>
        <text>{{item.catEmoji}}</text>
      </view>
      <view class="admin-product-info">
        <view class="admin-product-title ellipsis-2">{{item.title}}</view>
        <view class="flex-between">
          <text class="text-primary text-bold">¥{{item.price}}</text>
          <text class="text-sm text-muted">{{item.catLabel}} · {{item.status}}</text>
        </view>
      </view>
      <view class="btn btn-danger btn-sm" data-id="{{item.id}}" bindtap="adminDeleteProduct">🗑 删除</view>
    </view>
  </view>
</view>
