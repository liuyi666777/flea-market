.page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #f5f5f5;
}

.chat-list {
  flex: 1;
  padding: 20rpx;
}

.time-label {
  text-align: center;
  margin: 20rpx 0;
}

.time-label text {
  font-size: 22rpx;
  color: #ccc;
  background: none;
}

.msg-row {
  display: flex;
  align-items: flex-start;
  margin-bottom: 24rpx;
}

.msg-mine {
  flex-direction: row-reverse;
}

.chat-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  flex-shrink: 0;
  background: #f0f0f0;
}

.msg-other .chat-avatar {
  margin-right: 16rpx;
}

.msg-mine .chat-avatar {
  margin-left: 16rpx;
}

.msg-bubble {
  max-width: 460rpx;
  padding: 16rpx 22rpx;
  border-radius: 16rpx;
  font-size: 28rpx;
  line-height: 1.5;
  word-break: break-all;
}

.bubble-other {
  background: #fff;
  color: #333;
  border-top-left-radius: 4rpx;
}

.bubble-mine {
  background: #07c160;
  color: #fff;
  border-top-right-radius: 4rpx;
}

.input-bar {
  display: flex;
  align-items: center;
  padding: 16rpx 20rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  background: #fff;
  border-top: 1rpx solid #f0f0f0;
}

.chat-input {
  flex: 1;
  height: 72rpx;
  background: #f5f5f5;
  border-radius: 36rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
}

.send-btn {
  margin-left: 20rpx;
  padding: 0 28rpx;
  height: 72rpx;
  line-height: 72rpx;
  border-radius: 36rpx;
  font-size: 28rpx;
  color: #ccc;
  background: #f5f5f5;
}

.send-btn.active {
  color: #fff;
  background: #07c160;
}
