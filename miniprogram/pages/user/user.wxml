<view class="page">
  <!-- 用户信息头部 -->
  <view class="user-header">
    <view wx:if="{{isLogin}}">
      <view class="flex-align-center">
        <image class="avatar-lg" src="{{profile.avatar_url || '/images/default-avatar.png'}}" mode="aspectFill" />
        <view class="ml-20">
          <view class="nickname text-xl text-bold">{{profile.nickname || '用户'}}</view>
          <view class="text-sm mt-10" style="opacity:0.8">{{email}}</view>
        </view>
      </view>
    </view>

    <view wx:else class="login-prompt" bindtap="showLogin">
      <view class="avatar-placeholder">👤</view>
      <view class="mt-20 text-lg">点击登录</view>
      <view class="mt-10 text-sm" style="opacity:0.7">使用邮箱注册登录，开始交易之旅</view>
    </view>
  </view>

  <!-- 功能菜单 -->
  <view class="menu-section">
    <view class="menu-item" bindtap="goMyPublish">
      <text class="menu-icon">📦</text>
      <text class="menu-text flex-1">我发布的</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="goFavorites">
      <text class="menu-icon">⭐</text>
      <text class="menu-text flex-1">我的收藏</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="goMessages">
      <text class="menu-icon">💬</text>
      <text class="menu-text flex-1">我的消息</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" wx:if="{{isAdmin}}" bindtap="goAdmin">
      <text class="menu-icon">🛡️</text>
      <text class="menu-text flex-1">管理面板</text>
      <text class="menu-arrow">›</text>
    </view>
  </view>

  <!-- 退出登录 -->
  <view class="logout-section" wx:if="{{isLogin}}" bindtap="doLogout">
    <text class="text-muted">退出登录</text>
  </view>
</view>
