<view class="page">
  <!-- 用户信息头部 -->
  <view class="user-header">
    <view wx:if="{{isLogin}}">
      <view class="flex-align-center">
        <image class="avatar-lg" src="{{userInfo.avatarUrl || '/images/default-avatar.png'}}" mode="aspectFill" />
        <view class="ml-20">
          <view class="nickname text-xl text-bold">{{userInfo.nickName || '微信用户'}}</view>
          <view class="text-sm text-muted mt-10" wx:if="{{userInfo.schoolId}}">学号: {{userInfo.schoolId}}</view>
        </view>
      </view>
    </view>

    <view wx:else class="login-prompt" bindtap="doLogin">
      <view class="avatar-placeholder">👤</view>
      <view class="mt-20 text-lg">点击登录</view>
      <view class="mt-10 text-sm text-muted">授权微信信息，开始交易之旅</view>
    </view>
  </view>

  <!-- 功能菜单 -->
  <view class="menu-section">
    <view class="menu-item" bindtap="goMyPublish">
      <text class="menu-icon">📦</text>
      <text class="menu-text flex-1">我发布的</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="goFavorites">
      <text class="menu-icon">⭐</text>
      <text class="menu-text flex-1">我的收藏</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="goMessages">
      <text class="menu-icon">💬</text>
      <text class="menu-text flex-1">我的消息</text>
      <text class="menu-arrow">›</text>
    </view>
  </view>

  <!-- 退出登录 -->
  <view class="logout-section" wx:if="{{isLogin}}" bindtap="doLogout">
    <text class="text-muted">退出登录</text>
  </view>
</view>
