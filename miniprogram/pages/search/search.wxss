.page {
  min-height: 100vh;
  background: #fff;
}

.search-bar {
  display: flex;
  align-items: center;
  padding: 16rpx 20rpx;
  background: #fff;
}

.search-input-box {
  flex: 1;
  display: flex;
  align-items: center;
  height: 68rpx;
  background: #f5f5f5;
  border-radius: 34rpx;
  padding: 0 20rpx;
}

.search-icon {
  margin-right: 10rpx;
  font-size: 28rpx;
}

.search-field {
  flex: 1;
  font-size: 28rpx;
}

.search-clear {
  padding: 0 10rpx;
  color: #ccc;
  font-size: 24rpx;
}

.search-cancel {
  padding-left: 20rpx;
  font-size: 28rpx;
  color: #07c160;
  flex-shrink: 0;
}

.result-header {
  padding: 20rpx;
  font-size: 24rpx;
  color: #999;
}

.product-grid {
  display: flex;
  padding: 0 20rpx 20rpx;
  gap: 16rpx;
}

.product-col {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.history {
  padding-top: 20rpx;
}

.px-20 { padding-left: 20rpx; padding-right: 20rpx; }
.py-20 { padding-top: 20rpx; padding-bottom: 20rpx; }

.history-tags {
  display: flex;
  flex-wrap: wrap;
  padding: 0 20rpx;
  gap: 16rpx;
}

.history-tag {
  padding: 12rpx 24rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
  font-size: 26rpx;
  color: #666;
}
