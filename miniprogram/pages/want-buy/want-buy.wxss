.page {
  min-height: 100vh;
  padding-bottom: 20rpx;
}

.category-scroll {
  white-space: nowrap;
  padding: 16rpx 20rpx;
  background: #fff;
}

.category-item {
  display: inline-flex;
  align-items: center;
  height: 56rpx;
  padding: 0 24rpx;
  margin-right: 16rpx;
  border-radius: 28rpx;
  font-size: 26rpx;
  color: #666;
  background: #f5f5f5;
}

.category-item.active {
  color: #fff;
  background: #07c160;
}

.want-card {
  margin: 16rpx 20rpx;
}

.avatar-sm {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: #f0f0f0;
}

.want-title {
  line-height: 1.5;
}

.want-desc {
  line-height: 1.5;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.want-budget {
  font-size: 32rpx;
}

.status-tag {
  padding: 6rpx 16rpx;
  border-radius: 6rpx;
  font-size: 22rpx;
  color: #07c160;
  background: rgba(7, 193, 96, 0.1);
}

.status-tag.done {
  color: #999;
  background: #f0f0f0;
}

.mb-15 { margin-bottom: 15rpx; }
.mt-10 { margin-top: 10rpx; }
.mt-15 { margin-top: 15rpx; }

.fab {
  position: fixed;
  right: 40rpx;
  bottom: 120rpx;
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: #07c160;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  box-shadow: 0 8rpx 24rpx rgba(7, 193, 96, 0.35);
}
