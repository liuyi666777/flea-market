.page {
  min-height: 100vh;
  padding-bottom: 20rpx;
}

.status-tabs {
  display: flex;
  background: #fff;
  padding: 0 20rpx;
  position: sticky;
  top: 0;
  z-index: 10;
}

.status-tab {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  font-size: 28rpx;
  color: #666;
  border-bottom: 4rpx solid transparent;
}

.status-tab.active {
  color: #07c160;
  border-bottom-color: #07c160;
}

.product-grid {
  display: flex;
  padding: 20rpx;
  gap: 16rpx;
}

.product-col {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}
