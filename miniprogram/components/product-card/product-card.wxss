.product-card {
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.img-wrap {
  position: relative;
  width: 100%;
  height: 340rpx;
}

.product-img {
  width: 100%;
  height: 340rpx;
  background: #f0f0f0;
}

.product-badge {
  position: absolute;
  top: 12rpx;
  left: 12rpx;
  padding: 4rpx 14rpx;
  border-radius: 20rpx;
  font-size: 20rpx;
  font-weight: 600;
  color: #fff;
  z-index: 2;
}

.badge-hot {
  background: linear-gradient(135deg, #ff6b35, #ff4d2e);
  box-shadow: 0 2rpx 10rpx rgba(255, 107, 53, 0.4);
}

.badge-new {
  background: linear-gradient(135deg, #4e8cff, #3b6de0);
  box-shadow: 0 2rpx 10rpx rgba(78, 140, 255, 0.3);
}

.badge-sold {
  background: rgba(0, 0, 0, 0.5);
}

.product-info {
  padding: 16rpx 20rpx 20rpx;
}

.product-title {
  font-size: 28rpx;
  line-height: 1.4;
  margin-bottom: 12rpx;
  min-height: 78rpx;
}

.product-price {
  font-size: 34rpx;
}

.tag {
  display: inline-block;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
  font-size: 22rpx;
  color: #07c160;
  background: rgba(7, 193, 96, 0.1);
}
